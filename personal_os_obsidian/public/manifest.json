{
  "manifest_version": 3,
  "name": "Personal OS Hub",
  "version": "1.0.0",
  "description": "AI-powered Obsidian vault OS with slash commands and daily digest",
  "permissions": [
    "storage",
    "alarms",
    "sidePanel",
    "notifications"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
